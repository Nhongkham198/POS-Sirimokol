rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // DEVELOPER NOTE:
    // This rule allows anyone to read/write to your database.
    // This is necessary because the application currently uses a 
    // custom login system without Firebase Auth.
    // For production, it is HIGHLY RECOMMENDED to implement Firebase Auth
    // and secure these rules.
    // ===============================================================
    
    // Global rule for all documents
    match /{document=**} {
      allow read, write: if true;
    }
    
    // Explicit rules for common paths to ensure access
    match /branches/{branchId}/{collectionId}/{docId} {
      allow read, write: if true;
    }
    
    match /branches/{branchId}/{collectionId} {
      allow read, write: if true;
    }
    
    match /users/{docId} {
      allow read, write: if true;
    }
    
    match /leaveRequests/{docId} {
      allow read, write: if true;
    }
    
    match /signatureUrl/{docId} {
      allow read, write: if true;
    }
    
    match /logoUrl/{docId} {
      allow read, write: if true;
    }
    
    match /restaurantAddress/{docId} {
      allow read, write: if true;
    }
  }
}
